diff --git a/init/Kconfig b/init/Kconfig
index 324c2886b..408ba6f24 100644
--- a/init/Kconfig
+++ b/init/Kconfig
@@ -875,6 +875,25 @@ config UCLAMP_BUCKETS_COUNT
 
 	  If in doubt, use the default value.
 
+config GRR_SCHED
+	bool "Group Round-Robin Scheduler Class"
+	default y
+	help
+	  This option enables the Group Round-Robin Scheduling class (SCHED_GRR),
+	  which provides two disjoint scheduling groups with configurable CPU
+	  core allocation:
+
+	  - DEFAULT group: where tasks belong by default
+	  - PERFORMANCE group: for selectively assigned high-priority tasks
+
+	  Each group gets a dedicated set of CPU cores (50/50 split by default),
+	  and tasks are scheduled using round-robin within their group.
+
+	  The GRR class sits between RT and FAIR in the scheduling hierarchy:
+	  RT > GRR > FAIR > IDLE
+
+	  If unsure, say Y.
+
 endmenu
 

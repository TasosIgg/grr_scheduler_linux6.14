diff --git a/include/linux/sched/grr.h b/include/linux/sched/grr.h
new file mode 100644
index 000000000..2480641bc
--- /dev/null
+++ b/include/linux/sched/grr.h
@@ -0,0 +1,48 @@
+#ifndef _LINUX_SCHED_GRR_H
+#define _LINUX_SCHED_GRR_H
+
+#include <linux/list.h> /* for struct list_head */
+#include <linux/cpumask.h> /* cpumask_t */
+
+#ifdef CONFIG_GRR_SCHED
+
+#define GRR_TIMESLICE_MS (msecs_to_jiffies(100))
+#define GRR_DEFAULT 1
+#define GRR_PERFORMANCE 2
+
+/*
+ * The cpumasks of the two groups — defined in core.c or elsewhere.
+ */
+extern cpumask_t grr_default_cpus;
+extern cpumask_t grr_perf_cpus;
+
+/* Forward declarations to avoid cyclic includes */
+struct task_struct;
+struct rq;
+
+/* Per-task GRR data */
+struct task_grr {
+	struct list_head run_list;
+	unsigned int time_slice;
+	unsigned long last_start;
+	int group;
+	int on_list;
+	int on_rq;
+};
+
+/* Per-runqueue GRR data */
+struct grr_rq {
+	struct task_struct *curr;
+	int nr_running;
+	struct list_head queue;
+};
+
+/* Prototypes for functions used outside grr.c */
+void init_grr_rq(struct grr_rq *grr);
+int find_idlest_cpu_in_group(int group);
+int find_busiest_cpu_in_group(int group);
+bool can_migrate_task_grr(struct task_struct *p, int dst_cpu);
+
+#endif /* CONFIG_GRR_SCHED */
+
+#endif /* _LINUX_SCHED_GRR_H */
